<h2 style="font-size:16px;font-weight:700;margin:24px 0 8px;padding-bottom:6px;border-bottom:2px solid var(--accent);color:var(--text-primary)">Key Development Projects</h2>

<div style="margin:12px 0 20px">
<table style="width:100%;border-collapse:collapse">
<thead><tr style="background:var(--table-header-bg, #1d2033)">
  <th style="padding:8px;text-align:left;font-size:11px;text-transform:uppercase;letter-spacing:0.5px">Project</th>
